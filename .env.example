# ──────────────────────────────────────────────────────────────────────────────
# Rajput Foods Sweden — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Direct PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/rajput_db?schema=public"

# ── Authentication (better-auth) ──────────────────────────────────────────────
# Must be a long, random string. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"

# ── App URL ───────────────────────────────────────────────────────────────────
# Full URL of the app, used for redirects and email links.
# Local development:
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production example:
# NEXT_PUBLIC_APP_URL="https://rajputfoods.se"

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# SMTP credentials for sending order confirmation and admin notification emails.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-email-password"
# SMTP_FROM="Rajput Foods <noreply@rajputfoods.se>"
