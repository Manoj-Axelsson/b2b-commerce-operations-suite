# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rajput-foods-website"

# Authentication (better-auth)
BETTER_AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Transactional email (nodemailer, Gmail SMTP).
# Used for verification, password reset, and password-changed notices.
# EMAIL_PASS should be an app password, not your real Gmail password.
EMAIL_USER="you@example.com"
EMAIL_PASS="your-gmail-app-password"
