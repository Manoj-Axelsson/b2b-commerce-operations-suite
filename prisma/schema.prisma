generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id
  name             String
  email            String          @unique
  emailVerified    Boolean         @default(false)
  image            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  isApproved       Boolean         @default(false)
  role             String?
  twoFactorEnabled Boolean         @default(false)
  accounts         Account[]
  addresses        Address[]
  cart             Cart?
  orders           Order[]
  sessions         Session[]
  stockMovements   StockMovement[]
  wishlist         Wishlist[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("category")
}

model Product {
  id              String        @id @default(uuid())
  articleNo       String        @unique
  barcode         String?       @unique
  name            String
  brand           String
  weightValue     Int
  weightUnit      String
  ingredients     String?
  description     String?
  imageUrl        String?
  images          String[]
  price           Int
  discountPrice   Int?
  discountStart   DateTime?
  discountEnd     DateTime?
  discountType    DiscountType?
  quantity        Int           @default(0)
  minQuantity     Int           @default(5)
  expiryDate      DateTime?
  lastRestockedAt DateTime?
  isActive        Boolean       @default(true)
  isDeleted       Boolean       @default(false)
  categoryId      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  supplierId      String?

  cartItems      CartItem[]
  orderItems     OrderItem[]
  category       Category        @relation(fields: [categoryId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]
  wishlistedBy   Wishlist[]

  //FIXED: Many-to-many
  promotions Promotion[] @relation("ProductPromotions")

  @@index([categoryId])
  @@index([brand])
  @@index([expiryDate])
  @@index([quantity])
  @@index([categoryId, brand])
  @@index([discountStart, discountEnd])
  @@index([name])
  @@map("product")
}

// One cart per user — created on first write, cleared on order placement.
//
// CartItem.quantity is ADVISORY: a draft of user intent, clamped to stock at write
// time but never reserved. Authoritative stock checks happen during order placement
// under row-level locks on Product. Cart writes must remain non-blocking; do not
// add stock decrements or reservations here.
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@map("cart")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@map("cart_item")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist")
}

model Promotion {
  id            String  @id @default(uuid())
  code          String
  discountUnit  String
  discountValue Decimal @db.Decimal(10, 2)

  isActive  Boolean  @default(true)
  startDate DateTime
  endDate   DateTime

  // ✅ Matching relation
  products Product[] @relation("ProductPromotions")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id String @id @default(uuid())

  // ------------------------------------------------------
  // RELATIONS
  // ------------------------------------------------------

  userId    String
  addressId String?

  user User @relation(fields: [userId], references: [id])

  address Address? @relation(fields: [addressId], references: [id])

  items OrderItem[]

  adjustments OrderAdjustment[]
  events      OrderEvent[]

  // ------------------------------------------------------
  // ORDER WORKFLOW
  // ------------------------------------------------------

  status OrderStatus @default(IN_PROCESS)

  paymentStatus PaymentStatus @default(PENDING)

  sentToAdminMail Boolean @default(false)

  // ------------------------------------------------------
  // FINANCIALS
  // ------------------------------------------------------

  subtotalPrice Decimal? @db.Decimal(10, 2)

  adjustmentTotal Decimal @default(0) @db.Decimal(10, 2)

  totalPrice Decimal @db.Decimal(10, 2)

  // ------------------------------------------------------
  // DELIVERY SNAPSHOT
  // ------------------------------------------------------

  deliveryStreet     String
  deliveryCity       String
  deliveryPostalCode String
  deliveryCountry    String

  deliveryCompany String?
  deliveryContact String?
  deliveryPhone   String?

  deliveryNotes String?

  // ------------------------------------------------------
  // OPERATIONAL TIMESTAMPS
  // ------------------------------------------------------

  reviewedAt        DateTime?
  paymentReceivedAt DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?

  // ------------------------------------------------------
  // SYSTEM TIMESTAMPS & SECURITY
  // ------------------------------------------------------

  idempotencyKey String? @unique

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // ------------------------------------------------------
  // INDEXES
  // ------------------------------------------------------

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("order")
}

model OrderItem {
  id String @id @default(uuid())

  orderId   String
  productId String

  productName String
  sku         String?

  quantity Int

  price     Int // ← IMPORTANT: match your system (cents)
  lineTotal Int

  // NEW FIELDS (your promotions)
  discountApplied      Int     @default(0)
  appliedPromotionCode String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_item")
}

model OrderAdjustment {
  id String @id @default(uuid())

  orderId String

  type AdjustmentType

  description String?

  amount Decimal @db.Decimal(10, 2)

  createdBy String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderEvent {
  id String @id @default(uuid())

  orderId String

  previousStatus OrderStatus?
  nextStatus     OrderStatus

  actorId String

  actorRole String

  notes String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Settings {
  id                      String   @id @default(uuid())
  adminEmailNotifications Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("settings")
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  addressLabel String?  @default("Home")
  firstName    String
  lastName     String
  street       String
  houseNumber  String
  apartment    String?
  city         String
  postalCode   String
  country      String
  phoneNumber  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
  @@map("address")
}

model StockMovement {
  id                String          @id @default(uuid())
  productId         String
  changeType        StockChangeType
  quantity          Int
  note              String?
  performedByUserId String?
  createdAt         DateTime        @default(now())
  performedByUser   User?           @relation(fields: [performedByUserId], references: [id])
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_movement")
}

model Supplier {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model EmailJob {
  id      String @id @db.Uuid
  type    String
  payload Json

  dedupeKey String? @unique

  status      EmailJobStatus @default(PENDING)
  attempts    Int            @default(0)
  maxAttempts Int            @default(5)

  nextAttemptAt DateTime  @default(now())
  processingAt  DateTime?
  sentAt        DateTime?

  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, nextAttemptAt])
}

enum EmailJobStatus {
  PENDING
  PROCESSING
  SENT
  DEAD
}

enum UserRole {
  CUSTOMER
  ADMIN
  WAREHOUSE
  SYSTEM
}

enum OrderStatus {
  IN_PROCESS
  AWAITING_PAYMENT
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum DiscountType {
  SPECIAL_OFFER
  PROMOTION
  CLEARANCE
}

enum StockChangeType {
  RESTOCK
  SALE
  ADJUSTMENT
  DAMAGE
  RETURN
}

enum PaymentStatus {
  PENDING
  RECEIVED
  DENIED
}

enum AdjustmentType {
  DISCOUNT
  DELIVERY_FEE
  LOGISTICS
  HANDLING_FEE
}
