# Cloudinary Configuration
# Sign up for free at https://cloudinary.com/users/register/free

# Required: Your Cloudinary Cloud Name (found in Cloudinary Dashboard)
# This is public and safe to expose in frontend code (NEXT_PUBLIC prefix)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name_here

# Required for server-side uploads: Your Cloudinary API Key
# Keep this private - never expose in frontend code
CLOUDINARY_API_KEY=your_api_key_here

# Required for server-side uploads: Your Cloudinary API Secret
# Keep this private - never expose in frontend code
CLOUDINARY_API_SECRET=your_api_secret_here

